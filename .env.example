# Required: Your API Key
DEEPSEEK_API_KEY=your_api_key_here

# Optional: Base URL and Model
# Note: The default 'deepseek-chat' model does NOT support images (vision).
# For screen control features, you MUST use a vision-capable model (e.g., gpt-4o, claude-3-5-sonnet, or local llava).
# If using OpenAI compatible provider:
# MAD_BASE_URL=https://api.openai.com/v1
# MAD_MODEL=gpt-4o

# Default (will fail with image errors if used for screenshots):
MAD_BASE_URL=https://api.deepseek.com
MAD_MODEL=deepseek-chat
